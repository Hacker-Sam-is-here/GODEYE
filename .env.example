# Copy this file to .env for local development
# NEVER commit .env to git — it is gitignored

# AIS Stream (aisstream.io — free)
AISSTREAM_KEY=your_key_here

# ACLED Conflict Data (acleddata.com — free research access)
ACLED_EMAIL=your_email_here
ACLED_PASSWORD=your_key_here

# NASA FIRMS Fire Data (firms.modaps.eosdis.nasa.gov — free)
FIRMS_API_KEY=your_key_here

# N2YO Satellite Tracking (n2yo.com — free, 1000 req/h)
N2YO_API_KEY=your_key_here

# OSINT API endpoints
OSINT_PRIMARY_URL=https://anuapi.netlify.app/.netlify/functions/api
OSINT_FALLBACK_URL=https://api.b77bf911.workers.dev
